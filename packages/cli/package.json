{
  "name": "canopy-deploy",
  "version": "1.1.0",
  "description": "Canopy CLI — security scanner & deploy tool for vibecoded apps",
  "bin": {
    "canopy": "dist/index.js"
  },
  "scripts": {
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --external:ssh2 --banner:js='#!/usr/bin/env node'",
    "build": "npm run bundle"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "keywords": [
    "security",
    "scanner",
    "deploy",
    "vps",
    "hetzner",
    "docker",
    "cli",
    "vibecoding",
    "ai-native"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/KenEzekiel/canopy.git"
  },
  "author": "Canopy Contributors",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
